<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <%- include('partials/theme-init') %>
  <title><%= t('ingredients.title') %></title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials/nav') %>

  <h1><%= t('ingredients.heading') %></h1>
  <p class="hint"><%= t('ingredients.hint') %></p>

  <% ingredients.forEach(function(ing) { %>
    <form id="ing-form-<%= ing.id %>" action="/ingredients/<%= ing.id %>" method="POST"></form>
  <% }); %>

  <table class="ingredients-table">
    <thead>
      <tr><th><%= t('ingredients.name') %></th><th><%= t('ingredients.defaultUnit') %></th><th><%= t('ingredients.perishable') %></th><th></th></tr>
    </thead>
    <tbody>
      <% ingredients.forEach(function(ing) { %>
        <tr>
          <td><%= ing.name %></td>
          <td>
            <select name="default_unit" form="ing-form-<%= ing.id %>" onchange="this.form.requestSubmit()">
              <option value="">—</option>
              <% units.forEach(function(u) { %>
                <option value="<%= u %>" <%= ing.default_unit === u ? 'selected' : '' %>><%= u %></option>
              <% }); %>
            </select>
          </td>
          <td class="center">
            <input type="checkbox" name="is_perishable" form="ing-form-<%= ing.id %>" onchange="this.form.requestSubmit()" <%= ing.is_perishable ? 'checked' : '' %>>
          </td>
          <td>
            <form action="/ingredients/<%= ing.id %>/delete" method="POST" onsubmit="return confirm('<%= t('ingredients.confirmDelete') %>')">
              <button type="submit" class="danger"><%= t('ingredients.delete') %></button>
            </form>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>

  <% if (ingredients.length === 0) { %>
    <p class="empty"><%= t('ingredients.noneYet') %></p>
  <% } %>

  <h2><%= t('ingredients.addHeading') %></h2>
  <form action="/ingredients" method="POST" class="add-form">
    <label>
      <%= t('ingredients.name') %>
      <input type="text" name="name" required>
    </label>
    <label>
      <%= t('ingredients.defaultUnit') %>
      <select name="default_unit">
        <option value="">—</option>
        <% units.forEach(function(u) { %>
          <option value="<%= u %>"><%= u %></option>
        <% }); %>
      </select>
    </label>
    <label class="checkbox-label">
      <input type="checkbox" name="is_perishable">
      <%= t('ingredients.perishable') %>
    </label>
    <button type="submit"><%= t('ingredients.addButton') %></button>
  </form>
  <script src="/ingredients.js" defer></script>
</body>
</html>
